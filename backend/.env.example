# Database
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require"

# AI Providers
GEMINI_API_KEY="your-google-gemini-api-key"
GROQ_API_KEY="your-groq-api-key"
ANTHROPIC_API_KEY="your-anthropic-api-key"   # optional, untuk Claude

# Provider selection (default: generator=gemini, reviewer=groq)
AI_GENERATOR_PROVIDER=gemini
AI_REVIEWER_PROVIDER=groq

# AI Review threshold (0.0-1.0, default 0.8)
AI_REVIEW_CONFIDENCE_THRESHOLD=0.8

# Duplicate scan similarity (0.0-1.0, default 0.6)
DUPLICATE_SIMILARITY_THRESHOLD=0.6
