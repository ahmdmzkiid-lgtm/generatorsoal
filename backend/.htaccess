# ============================================
# .htaccess BACKEND - UNTUK gen.stubia.id
# Letakkan di document root subdomain backend
# (biasanya di public_html/gen/)
# NOTE: Jika pakai Setup Node.js bawaan Hostinger,
# proxy sudah diatur otomatis oleh hPanel.
# File ini opsional tapi recommended.
# ============================================

# ============================================
# 1. SECURITY HEADERS
# ============================================
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ============================================
# 2. BLOCK AKSES FILE SENSITIF
# ============================================
<FilesMatch "\.(env|json|md|lock|gitignore|log|ts|tsx)$">
    Require all denied
</FilesMatch>

<FilesMatch "^(package|package-lock|tsconfig|vitest)\.(json|js)$">
    Require all denied
</FilesMatch>

# ============================================
# 3. CEGAH DIRECTORY LISTING
# ============================================
Options -Indexes

# ============================================
# 4. KOMPRESI GZIP
# ============================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
